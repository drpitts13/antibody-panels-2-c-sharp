<UserControl x:Class="AntibodyPanels.Views.RulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Rule List -->
        <DockPanel Grid.Column="0" Margin="6">
            <TextBlock DockPanel.Dock="Top" Text="Custom Rule-out Rules" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="Add" Command="{Binding AddCommand}" Width="60" Margin="0,0,4,0"/>
                <Button Content="Edit" Command="{Binding EditCommand}" Width="60" Margin="0,0,4,0"/>
                <Button Content="Delete" Command="{Binding DeleteCommand}" Width="60" Margin="0,0,4,0"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Width="65"/>
            </StackPanel>
            <DataGrid ItemsSource="{Binding Rules}"
                      SelectedItem="{Binding SelectedRule}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Antibody" Binding="{Binding Antibody}" Width="100"/>
                    <DataGridCheckBoxColumn Header="Het OK" Binding="{Binding HeterozygousOk}" Width="65"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <!-- Right: Rule Detail -->
        <ScrollViewer Grid.Column="2" Margin="6">
            <StackPanel>
                <TextBlock Text="Rule Details" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>

                    <Label Content="Name:" Grid.Row="0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedRule.Name}"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>

                    <Label Content="Antibody:" Grid.Row="1" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedRule.Antibody}"
                               VerticalAlignment="Center"/>

                    <Label Content="Exception Antigen:" Grid.Row="2" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedRule.ExceptionAntigen}"
                               VerticalAlignment="Center"/>

                    <Label Content="Heterozygous OK:" Grid.Row="3" VerticalAlignment="Center"/>
                    <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding SelectedRule.HeterozygousOk, Mode=OneWay}"
                              IsEnabled="False" VerticalAlignment="Center" Margin="0,6"/>

                    <Label Content="Min Ruleout Count:" Grid.Row="4" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedRule.MinRuleoutCount}"
                               VerticalAlignment="Center"/>

                    <Label Content="Description:" Grid.Row="5" VerticalAlignment="Top" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedRule.Description}"
                               TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,4,0,0"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="AntibodyPanels.Views.PanelsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AntibodyPanels.Views">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Panel List -->
        <DockPanel Grid.Column="0" Margin="6">
            <TextBlock DockPanel.Dock="Top" Text="Panels" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="Add" Command="{Binding AddCommand}" Width="60" Margin="0,0,4,0"/>
                <Button Content="Edit" Command="{Binding EditCommand}" Width="60" Margin="0,0,4,0"/>
                <Button Content="Copy" Command="{Binding CopyCommand}" Width="60" Margin="0,0,4,0"/>
                <Button Content="Delete" Command="{Binding DeleteCommand}" Width="60"/>
            </StackPanel>
            <DataGrid ItemsSource="{Binding Panels}"
                      SelectedItem="{Binding SelectedPanel}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Lot #" Binding="{Binding LotNumber}" Width="80"/>
                    <DataGridTextColumn Header="Cells" Binding="{Binding NumCells}" Width="50"/>
                    <DataGridTextColumn Header="Expires" Binding="{Binding ExpirationDate}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <!-- Right: Antigen Grid -->
        <DockPanel Grid.Column="2" Margin="6">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock FontWeight="Bold" FontSize="14">
                    <Run Text="Antigen Grid: "/>
                    <Run Text="{Binding SelectedPanel.Name}"/>
                </TextBlock>
                <Button Content="Save All Changes" Command="{Binding SaveCellsCommand}"
                        HorizontalAlignment="Right" Padding="8,2"/>
            </DockPanel>

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <DataGrid x:Name="AntigenGrid"
                          ItemsSource="{Binding CellRows}"
                          AutoGenerateColumns="False"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionUnit="Cell"
                          FontSize="13">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cell" Binding="{Binding CellNumber}" Width="50" IsReadOnly="True"/>
                        <DataGridComboBoxColumn Header="D"   SelectedItemBinding="{Binding D,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="C"   SelectedItemBinding="{Binding C,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="c"   SelectedItemBinding="{Binding c,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="E"   SelectedItemBinding="{Binding E,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="e"   SelectedItemBinding="{Binding e,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="f"   SelectedItemBinding="{Binding f,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="Cw"  SelectedItemBinding="{Binding Cw,  UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="V"   SelectedItemBinding="{Binding V,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="K"   SelectedItemBinding="{Binding K,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="k"   SelectedItemBinding="{Binding k,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="Kpa" SelectedItemBinding="{Binding Kpa, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Kpb" SelectedItemBinding="{Binding Kpb, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Jsa" SelectedItemBinding="{Binding Jsa, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Jsb" SelectedItemBinding="{Binding Jsb, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Jka" SelectedItemBinding="{Binding Jka, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Jkb" SelectedItemBinding="{Binding Jkb, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Fya" SelectedItemBinding="{Binding Fya, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Fyb" SelectedItemBinding="{Binding Fyb, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Lea" SelectedItemBinding="{Binding Lea, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Leb" SelectedItemBinding="{Binding Leb, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="M"   SelectedItemBinding="{Binding M,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="N"   SelectedItemBinding="{Binding N,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="S"   SelectedItemBinding="{Binding S,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="s"   SelectedItemBinding="{Binding s,   UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                        <DataGridComboBoxColumn Header="Lua" SelectedItemBinding="{Binding Lua, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Lub" SelectedItemBinding="{Binding Lub, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="Xga" SelectedItemBinding="{Binding Xga, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="45"/>
                        <DataGridComboBoxColumn Header="P1"  SelectedItemBinding="{Binding P1,  UpdateSourceTrigger=PropertyChanged}" ItemsSource="{x:Static local:PanelsView.AntigenValues}" Width="40"/>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>

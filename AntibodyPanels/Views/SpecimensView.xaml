<UserControl x:Class="AntibodyPanels.Views.SpecimensView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Specimen List -->
        <DockPanel Grid.Column="0" Margin="6">
            <TextBlock DockPanel.Dock="Top" Text="Specimens" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="Add" Command="{Binding AddCommand}" Width="60" Margin="0,0,4,0"/>
                <Button Content="Edit" Command="{Binding EditCommand}" Width="60" Margin="0,0,4,0"/>
                <Button Content="Delete" Command="{Binding DeleteCommand}" Width="60" Margin="0,0,4,0"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Width="65" Margin="0,0,8,0"/>
                <CheckBox Content="Show Inactive" IsChecked="{Binding ShowInactive}" VerticalAlignment="Center"/>
            </StackPanel>
            <DataGrid ItemsSource="{Binding Specimens}"
                      SelectedItem="{Binding SelectedSpecimen}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Accession #" Binding="{Binding AccessionNumber}" Width="130"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="70"/>
                    <DataGridTextColumn Header="Expiration" Binding="{Binding ExpirationDate}" Width="90"/>
                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedDate}" Width="90"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" IsReadOnly="True" Width="50"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <!-- Right: Detail panes -->
        <DockPanel Grid.Column="2" Margin="6">
            <TextBlock DockPanel.Dock="Top" FontWeight="Bold" FontSize="14" Margin="0,0,0,6">
                <Run Text="Details: "/>
                <Run Text="{Binding SelectedSpecimen.AccessionNumber}"/>
            </TextBlock>

            <!-- Linked Panels -->
            <GroupBox DockPanel.Dock="Top" Header="Linked Panels" Margin="0,0,0,8" Padding="6">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Attach Panel" Command="{Binding AttachPanelCommand}" Margin="0,0,6,0"/>
                        <Button Content="Detach" Command="{Binding DetachPanelCommand}"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding LinkedPanels}"
                             SelectedItem="{Binding SelectedLinkedPanel}"
                             DisplayMemberPath="Name" Height="100"/>
                </DockPanel>
            </GroupBox>

            <!-- Suspected Antibodies -->
            <GroupBox DockPanel.Dock="Top" Header="Suspected Antibodies" Margin="0,0,0,8" Padding="6">
                <DataGrid ItemsSource="{Binding Antibodies}" IsReadOnly="True"
                          AutoGenerateColumns="False" Height="120"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Antibody" Binding="{Binding Antibody}" Width="*"/>
                        <DataGridTextColumn Header="Score" Binding="{Binding ProbabilityDisplay}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Ruled-out Antibodies -->
            <GroupBox Header="Ruled-out Antibodies" Padding="6">
                <DataGrid ItemsSource="{Binding Ruleouts}" IsReadOnly="True"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Antibody" Binding="{Binding Antibody}" Width="*"/>
                        <DataGridTextColumn Header="Count" Binding="{Binding RuleoutCount}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </DockPanel>
    </Grid>
</UserControl>

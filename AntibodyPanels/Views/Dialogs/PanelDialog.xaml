<Window x:Class="AntibodyPanels.Views.Dialogs.PanelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel" SizeToContent="WidthAndHeight" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16,12,16,12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <Label Content="Panel Name:" Grid.Row="0" VerticalAlignment="Center"/>
            <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,2"/>

            <Label Content="Lot Number:" Grid.Row="1" VerticalAlignment="Center"/>
            <TextBox x:Name="LotBox" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,2"/>

            <Label Content="Vendor:" Grid.Row="2" VerticalAlignment="Center"/>
            <TextBox x:Name="VendorBox" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="0,2"/>

            <Label Content="Number of Cells:" Grid.Row="3" VerticalAlignment="Center"/>
            <TextBox x:Name="NumCellsBox" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"
                     Margin="0,2" Text="16"/>

            <Label Content="Starting Cell #:" Grid.Row="4" VerticalAlignment="Center"/>
            <TextBox x:Name="StartCellBox" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center"
                     Margin="0,2" Text="1"
                     ToolTip="First cell number (e.g. enter 12 if this panel begins at cell 12)"/>

            <Label Content="Expiration Date:" Grid.Row="5" VerticalAlignment="Center"/>
            <DatePicker x:Name="ExpirationPicker" Grid.Row="5" Grid.Column="1"
                        VerticalAlignment="Center" Margin="0,2"
                        SelectedDateChanged="ExpirationPicker_SelectedDateChanged"/>

            <Label Content="Include AC:" Grid.Row="6" VerticalAlignment="Center"/>
            <CheckBox x:Name="IncludeAcCheck" Grid.Row="6" Grid.Column="1"
                      VerticalAlignment="Center" Margin="0,2"/>

            <Label Content="Active:" Grid.Row="7" VerticalAlignment="Center"/>
            <CheckBox x:Name="ActiveCheck" Grid.Row="7" Grid.Column="1"
                      VerticalAlignment="Center" Margin="0,2" IsChecked="True"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Save" Width="84" Margin="0,0,8,0" Click="SaveClick" IsDefault="True"/>
            <Button Content="Cancel" Width="84" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>

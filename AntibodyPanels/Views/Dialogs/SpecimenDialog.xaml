<Window x:Class="AntibodyPanels.Views.Dialogs.SpecimenDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Specimen" SizeToContent="WidthAndHeight" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Padding="16">
    <StackPanel Margin="16,12,16,12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <Label Content="Accession Number:" Grid.Row="0" VerticalAlignment="Center"/>
            <TextBox x:Name="AccessionBox" Grid.Row="0" Grid.Column="1"
                     VerticalAlignment="Center" Margin="0,2"/>

            <Label Content="Type:" Grid.Row="1" VerticalAlignment="Center"/>
            <ComboBox x:Name="TypeBox" Grid.Row="1" Grid.Column="1"
                      VerticalAlignment="Center" Margin="0,2"/>

            <Label Content="Expiration Date:" Grid.Row="2" VerticalAlignment="Center"/>
            <DatePicker x:Name="ExpirationPicker" Grid.Row="2" Grid.Column="1"
                        VerticalAlignment="Center" Margin="0,2"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Save" Width="84" Margin="0,0,8,0" Click="SaveClick" IsDefault="True"/>
            <Button Content="Cancel" Width="84" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>

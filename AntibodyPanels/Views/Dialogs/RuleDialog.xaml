<Window x:Class="AntibodyPanels.Views.Dialogs.RuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rule" SizeToContent="Height" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <StackPanel Margin="16,12,16,12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="155"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="72"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <Label Content="Rule Name:" Grid.Row="0" VerticalAlignment="Center"/>
            <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,2"/>

            <Label Content="Antibody:" Grid.Row="1" VerticalAlignment="Center"/>
            <ComboBox x:Name="AntibodyBox" Grid.Row="1" Grid.Column="1"
                      VerticalAlignment="Center" Margin="0,2" IsEditable="True"/>

            <Label Content="Description:" Grid.Row="2" VerticalAlignment="Top" Margin="0,6,0,0"/>
            <TextBox x:Name="DescBox" Grid.Row="2" Grid.Column="1" Margin="0,4"
                     TextWrapping="Wrap" AcceptsReturn="True"/>

            <Label Content="Exception Antigen:" Grid.Row="3" VerticalAlignment="Center"/>
            <ComboBox x:Name="ExceptionAntigenBox" Grid.Row="3" Grid.Column="1"
                      VerticalAlignment="Center" Margin="0,2" IsEditable="True"/>

            <Label Content="Heterozygous OK:" Grid.Row="4" VerticalAlignment="Center"/>
            <CheckBox x:Name="HeterozygousCheck" Grid.Row="4" Grid.Column="1"
                      VerticalAlignment="Center" Margin="0,2"/>

            <Label Content="Min Ruleout Count:" Grid.Row="5" VerticalAlignment="Center"/>
            <TextBox x:Name="MinCountBox" Grid.Row="5" Grid.Column="1"
                     VerticalAlignment="Center" Margin="0,2" Text="3"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Save" Width="84" Margin="0,0,8,0" Click="SaveClick" IsDefault="True"/>
            <Button Content="Cancel" Width="84" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>

<Window x:Class="AntibodyPanels.Views.Dialogs.SelectPanelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Panel" Height="340" Width="420"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Select a panel to attach:" Margin="0,0,0,6"/>
        <ListBox x:Name="PanelList" Grid.Row="1"
                 DisplayMemberPath="Name"
                 MouseDoubleClick="PanelList_DoubleClick"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Attach" Width="80" Margin="0,0,8,0" Click="AttachClick" IsDefault="True"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

<UserControl x:Class="AntibodyPanels.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AntibodyPanels.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Search by Antigen Profile" FontWeight="Bold"
                   FontSize="14" Margin="8,8,0,4"/>

        <!-- Criteria grid with scroll navigation buttons -->
        <Grid Grid.Row="1" Margin="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                <DataGrid x:Name="CriteriaGrid"
                          ItemsSource="{Binding Criteria}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          CanUserDeleteRows="False" HeadersVisibility="Column"
                          GridLinesVisibility="Vertical" MaxHeight="160">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Antigen" Binding="{Binding Antigen}" Width="70" IsReadOnly="True"/>
                        <DataGridComboBoxColumn Header="Criterion" Width="80"
                            SelectedItemBinding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}"
                            ItemsSource="{x:Static vm:AntigenCriterionRow.Options}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                <RepeatButton Content="▲" Height="28" Width="26" Focusable="False"
                              ToolTip="Scroll up" Margin="0,0,0,4"
                              Click="CriteriaScrollUp_Click"/>
                <RepeatButton Content="▼" Height="28" Width="26" Focusable="False"
                              ToolTip="Scroll down"
                              Click="CriteriaScrollDown_Click"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,6,0,6">
            <Button Content="Search" Command="{Binding SearchCommand}" Width="80" Margin="0,0,8,0" FontWeight="Bold"/>
            <Button Content="Clear" Command="{Binding ClearCommand}" Width="80"/>
            <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                       Text="{Binding Results.Count, StringFormat='Results: {0}'}" FontStyle="Italic"/>
        </StackPanel>

        <!-- Results -->
        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="8,0,8,8">
            <DataGrid ItemsSource="{Binding Results}" IsReadOnly="True"
                      AutoGenerateColumns="False" GridLinesVisibility="All"
                      HeadersVisibility="Column" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Panel" Binding="{Binding PanelName}" Width="150"/>
                    <DataGridTextColumn Header="Lot" Binding="{Binding LotNumber}" Width="90"/>
                    <DataGridTextColumn Header="Cell" Binding="{Binding CellNumber}" Width="50"/>
                    <DataGridTextColumn Header="D"   Binding="{Binding D}"   Width="35"/>
                    <DataGridTextColumn Header="C"   Binding="{Binding C}"   Width="35"/>
                    <DataGridTextColumn Header="c"   Binding="{Binding c}"   Width="35"/>
                    <DataGridTextColumn Header="E"   Binding="{Binding E}"   Width="35"/>
                    <DataGridTextColumn Header="e"   Binding="{Binding e}"   Width="35"/>
                    <DataGridTextColumn Header="f"   Binding="{Binding f}"   Width="35"/>
                    <DataGridTextColumn Header="Cw"  Binding="{Binding Cw}"  Width="40"/>
                    <DataGridTextColumn Header="V"   Binding="{Binding V}"   Width="35"/>
                    <DataGridTextColumn Header="K"   Binding="{Binding K}"   Width="35"/>
                    <DataGridTextColumn Header="k"   Binding="{Binding k}"   Width="35"/>
                    <DataGridTextColumn Header="Kpa" Binding="{Binding Kpa}" Width="40"/>
                    <DataGridTextColumn Header="Kpb" Binding="{Binding Kpb}" Width="40"/>
                    <DataGridTextColumn Header="Jsa" Binding="{Binding Jsa}" Width="40"/>
                    <DataGridTextColumn Header="Jsb" Binding="{Binding Jsb}" Width="40"/>
                    <DataGridTextColumn Header="Jka" Binding="{Binding Jka}" Width="40"/>
                    <DataGridTextColumn Header="Jkb" Binding="{Binding Jkb}" Width="40"/>
                    <DataGridTextColumn Header="Fya" Binding="{Binding Fya}" Width="40"/>
                    <DataGridTextColumn Header="Fyb" Binding="{Binding Fyb}" Width="40"/>
                    <DataGridTextColumn Header="Lea" Binding="{Binding Lea}" Width="40"/>
                    <DataGridTextColumn Header="Leb" Binding="{Binding Leb}" Width="40"/>
                    <DataGridTextColumn Header="M"   Binding="{Binding M}"   Width="35"/>
                    <DataGridTextColumn Header="N"   Binding="{Binding N}"   Width="35"/>
                    <DataGridTextColumn Header="S"   Binding="{Binding S}"   Width="35"/>
                    <DataGridTextColumn Header="s"   Binding="{Binding s}"   Width="35"/>
                    <DataGridTextColumn Header="Lua" Binding="{Binding Lua}" Width="40"/>
                    <DataGridTextColumn Header="Lub" Binding="{Binding Lub}" Width="40"/>
                    <DataGridTextColumn Header="Xga" Binding="{Binding Xga}" Width="40"/>
                    <DataGridTextColumn Header="P1"  Binding="{Binding P1}"  Width="38"/>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
    </Grid>
</UserControl>
